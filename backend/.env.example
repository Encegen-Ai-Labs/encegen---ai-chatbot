# ══════════════════════════════════════════════════════
#  Encegen AI Labs — Backend Environment Variables
# ══════════════════════════════════════════════════════

# 1. Groq API Key
GROQ_API_KEY=gsk_your_groq_api_key_here

# ──────────────────────────────────────────────────────
# 2. GoDaddy Email — SMTP credentials
#
# GODADDY_USER  = the email address used to SEND (SMTP login)
# GODADDY_PASS  = its GoDaddy email password
# GODADDY_TO    = where notifications are DELIVERED (your inbox)
#
# RECOMMENDED SETUP (best inbox delivery):
#   Create a separate noreply@encegenailabs.com in GoDaddy.
#   Emails arrive FROM noreply@ TO sales@ — not a self-send.
#
#   GODADDY_USER=noreply@encegenailabs.com
#   GODADDY_PASS=NoreplyAccountPassword
#   GODADDY_TO=sales@encegenailabs.com
#
# SIMPLE SETUP (if you don't want to create noreply@):
#   GODADDY_USER=sales@encegenailabs.com
#   GODADDY_PASS=YourGoDaddyEmailPassword
#   GODADDY_TO=sales@encegenailabs.com
# ──────────────────────────────────────────────────────
GODADDY_USER=noreply@encegenailabs.com
GODADDY_PASS=YourGoDaddyEmailPassword
GODADDY_TO=sales@encegenailabs.com
